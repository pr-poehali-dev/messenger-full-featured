{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Reject empty username",
      "method": "POST",
      "path": "/",
      "body": {"action": "send", "username": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Send code to username",
      "method": "POST",
      "path": "/",
      "body": {"action": "send", "username": "testuser_orbit"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify", "username": "testuser_orbit", "code": "0000"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}