{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Incoming with no user",
      "method": "GET",
      "path": "/?action=incoming&user_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"call": null},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "GET",
      "path": "/?action=nope",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
