{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Search empty returns empty",
      "method": "GET",
      "path": "/?action=search&q=a",
      "expectedStatus": 200,
      "expectedBody": {"users": [], "channels": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
